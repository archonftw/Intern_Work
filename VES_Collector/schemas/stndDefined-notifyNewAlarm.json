{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VesEventStndDefinedNotifyNewAlarmSchema",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {
      "type": "object",
      "required": ["commonEventHeader", "stndDefinedFields"],
      "properties": {
        "commonEventHeader": {
          "type": "object",
          "required": [
            "domain",
            "eventId",
            "eventName",
            "eventType",
            "sequence",
            "priority",
            "reportingEntityName",
            "sourceName",
            "startEpochMicrosec",
            "lastEpochMicrosec",
            "nfNamingCode",
            "nfVendorName",
            "timeZoneOffset",
            "version",
            "stndDefinedNamespace",
            "vesEventListenerVersion"
          ],
          "properties": {
            "domain": { "type": "string" },
            "eventId": { "type": "string" },
            "eventName": { "type": "string" },
            "eventType": { "type": "string" },
            "sequence": { "type": "integer" },
            "priority": { "type": "string", "enum": ["High", "Medium", "Low", "Critical"] },
            "reportingEntityId": { "type": "string" },
            "reportingEntityName": { "type": "string" },
            "sourceId": { "type": "string" },
            "sourceName": { "type": "string" },
            "startEpochMicrosec": { "type": "string" },
            "lastEpochMicrosec": { "type": "string" },
            "nfNamingCode": { "type": "string" },
            "nfVendorName": { "type": "string" },
            "timeZoneOffset": { "type": "string" },
            "version": { "type": "string" },
            "stndDefinedNamespace": { "type": "string" },
            "vesEventListenerVersion": { "type": "string" }
          }
        },
        "stndDefinedFields": {
          "type": "object",
          "required": [
            "schemaReference",
            "data",
            "stndDefinedFieldsVersion"
          ],
          "properties": {
            "schemaReference": { "type": "string", "format": "uri" },
            "stndDefinedFieldsVersion": { "type": "string" },
            "data": {
              "type": "object",
              "required": [
                "href",
                "notificationId",
                "notificationType",
                "eventTime",
                "systemDN",
                "alarmId",
                "alarmType",
                "probableCause",
                "specificProblem",
                "perceivedSeverity",
                "backedUpStatus",
                "backUpObject",
                "trendIndication",
                "thresholdInfo",
                "correlatedNotifications",
                "stateChangeDefinition",
                "monitoredAttributes",
                "proposedRepairActions",
                "additionalText",
                "additionalInformation",
                "rootCauseIndicator"
              ],
              "properties": {
                "href": { "type": "string" },
                "notificationId": { "type": "integer" },
                "notificationType": { "type": "string" },
                "eventTime": { "type": "string" },
                "systemDN": { "type": "string" },
                "alarmId": { "type": "string" },
                "alarmType": { "type": "string" },
                "probableCause": { "type": "string" },
                "specificProblem": { "type": "string" },
                "perceivedSeverity": { "type": "string" },
                "backedUpStatus": { "type": "boolean" },
                "backUpObject": { "type": "string" },
                "trendIndication": { "type": "string" },
                "thresholdInfo": {
                  "type": "object",
                  "required": ["observedMeasurement", "observedValue"],
                  "properties": {
                    "observedMeasurement": { "type": "string" },
                    "observedValue": { "type": "number" }
                  }
                },
                "correlatedNotifications": { "type": "array" },
                "stateChangeDefinition": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["operational-state"],
                    "properties": {
                      "operational-state": { "type": "string" }
                    }
                  }
                },
                "monitoredAttributes": {
                  "type": "object",
                  "required": ["interface"],
                  "properties": {
                    "interface": { "type": "string" }
                  }
                },
                "proposedRepairActions": { "type": "string" },
                "additionalText": { "type": "string" },
                "additionalInformation": {
                  "type": "object",
                  "required": ["eventTime", "equipType", "vendor", "model"],
                  "properties": {
                    "eventTime": { "type": "string" },
                    "equipType": { "type": "string" },
                    "vendor": { "type": "string" },
                    "model": { "type": "string" }
                  }
                },
                "rootCauseIndicator": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}