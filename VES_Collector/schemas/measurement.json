{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VesEventMeasurementSchema",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {
      "type": "object",
      "required": ["commonEventHeader", "measurementFields"],
      "properties": {
        "commonEventHeader": {
          "type": "object",
          "required": [
            "domain",
            "eventId",
            "eventName",
            "eventType",
            "sequence",
            "priority",
            "reportingEntityName",
            "sourceName",
            "startEpochMicrosec",
            "lastEpochMicrosec",
            "internalHeaderFields",
            "version",
            "vesEventListenerVersion"
          ],
          "properties": {
            "domain": { "type": "string" },
            "eventId": { "type": "string" },
            "eventName": { "type": "string" },
            "eventType": { "type": "string" },
            "sequence": { "type": "integer" },
            "priority": { "type": "string", "enum": ["High", "Medium", "Low", "Critical"] },
            "reportingEntityId": { "type": "string" },
            "reportingEntityName": { "type": "string" },
            "sourceId": { "type": "string" },
            "sourceName": { "type": "string" },
            "startEpochMicrosec": { "type": "string" },
            "lastEpochMicrosec": { "type": "string" },
            "internalHeaderFields": {
              "type": "object",
              "required": ["intervalStartTime", "intervalEndTime"],
              "properties": {
                "intervalStartTime": { "type": "string" },
                "intervalEndTime": { "type": "string" }
              }
            },
            "version": { "type": "string" },
            "vesEventListenerVersion": { "type": "string" }
          }
        },
        "measurementFields": {
          "type": "object",
          "required": [
            "additionalFields",
            "additionalMeasurements",
            "additionalObjects",
            "codecUsageArray",
            "concurrentSessions",
            "configuredEntities",
            "cpuUsageArray",
            "diskUsageArray",
            "featureUsageArray",
            "filesystemUsageArray",
            "hugePagesArray",
            "ipmi",
            "latencyDistribution",
            "loadArray",
            "machineCheckExceptionArray",
            "meanRequestLatency",
            "measurementInterval",
            "measurementFieldsVersion",
            "memoryUsageArray",
            "numberOfMediaPortsInUse",
            "requestRate",
            "nfcScalingMetric",
            "nicPerformanceArray",
            "processStatsArray"
          ],
          "properties": {
            "additionalFields": { "type": "object" },
            "additionalMeasurements": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "hashMap"],
                "properties": {
                  "name": { "type": "string" },
                  "hashMap": {
                    "type": "object",
                    "properties": {
                      "es": { "type": "string" },
                      "ses": { "type": "string" },
                      "cses": { "type": "string" },
                      "unavailability": { "type": "string" }
                    }
                  }
                }
              }
            },
            "additionalObjects": { "type": "array" },
            "codecUsageArray": { "type": "array" },
            "concurrentSessions": { "type": "integer" },
            "configuredEntities": { "type": "integer" },
            "cpuUsageArray": { "type": "array" },
            "diskUsageArray": { "type": "array" },
            "featureUsageArray": { 
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "filesystemUsageArray": { "type": "array" },
            "hugePagesArray": { "type": "array" },
            "ipmi": { "type": "object" },
            "latencyDistribution": { "type": "array" },
            "loadArray": { "type": "array" },
            "machineCheckExceptionArray": { "type": "array" },
            "meanRequestLatency": { "type": "integer" },
            "measurementInterval": { "type": "integer" },
            "measurementFieldsVersion": { "type": "string" },
            "memoryUsageArray": { "type": "array" },
            "numberOfMediaPortsInUse": { "type": "integer" },
            "requestRate": { "type": "integer" },
            "nfcScalingMetric": { "type": "integer" },
            "nicPerformanceArray": { "type": "array" },
            "processStatsArray": { "type": "array" }
          }
        }
      }
    }
  }
}